{
  "name": "chemvault-files-windows",
  "private": true,
  "description": "ChemVault Files desktop cloud drive app for Windows.",
  "author": "ChemVault",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5177",
    "dev:electron": "cross-env CHEMVAULT_DESKTOP_DEV_URL=http://127.0.0.1:5177 electron .",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json && vite build",
    "test": "vitest run --config vite.config.ts",
    "package": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --win nsis --publish never",
    "release": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^6.0.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "science.chemvault.files",
    "productName": "ChemVault Files",
    "directories": {
      "output": "../../dist/windows"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ChemVaultFilesSetup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://download.chemvault.science/files/windows/"
      }
    ]
  },
  "allowScripts": {
    "electron": true,
    "electron-winstaller": true,
    "esbuild": true
  }
}
