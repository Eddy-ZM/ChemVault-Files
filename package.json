{
  "name": "chemvault-files",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "yaml": "2.8.3"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/relativize-assets.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "astro check && npm test",
    "build:api-client": "tsc -p packages/api-client/tsconfig.json",
    "dev:windows": "npm --prefix apps/windows run dev",
    "build:windows": "npm --prefix apps/windows run build",
    "package:windows": "npm --prefix apps/windows run package",
    "release:windows": "npm --prefix apps/windows run release",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2026-06-11",
    "types:cf": "wrangler types"
  },
  "dependencies": {
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.110.0"
  }
}
