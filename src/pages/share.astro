---
import BrandMark from "../components/BrandMark.astro";
import "../styles/chemvault-files.css";
import "../styles/exhibition-theme.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/assets/favicon-192.png" type="image/png" sizes="192x192" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/assets/chemvault-apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07111f" />
    <title>ChemVault Files Share</title>
    <meta name="description" content="Read-only ChemVault Files share preview." />
  </head>
  <body class="share-body">
    <main class="share-page" data-cv-share-page>
      <header class="share-topbar">
        <BrandMark />
        <span>Shared file</span>
      </header>
      <section class="share-view panel" data-cv-share-view>
        <div class="activity-empty">Loading shared file...</div>
      </section>
    </main>
    <script>
      import { bootChemVaultShare } from "../scripts/chemvault-share";
      bootChemVaultShare();
    </script>
  </body>
</html>
