<aside class="inspector panel" aria-label="Selected file inspector" data-cv-inspector>
  <header class="inspector__header">
    <span class="file-type-icon" data-ext="FILE" data-cv-selected-file-icon>FILE</span>
    <div>
      <h2 data-cv-selected-file-name>Loading files</h2>
    </div>
    <button class="ghost-icon inspector__close" type="button" aria-label="Close inspector">
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
  </header>

  <nav class="inspector-tabs" aria-label="Inspector tabs" data-cv-inspector-tabs>
    <button class="inspector-tabs__tab is-active" type="button" aria-selected="true">Details</button>
    <button class="inspector-tabs__tab" type="button">Preview</button>
    <button class="inspector-tabs__tab" type="button">Activity</button>
  </nav>

  <div class="inspector__body">
    <dl class="metadata-list" data-cv-metadata-list>
      <div><dt>Status</dt><dd>Reading library metadata.</dd></div>
    </dl>
  </div>

  <footer class="inspector__actions">
    <button class="button button--primary button--wide" type="button" data-cv-download-button disabled>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 15v4h14v-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Download
      <svg class="icon button__chevron" viewBox="0 0 24 24" aria-hidden="true">
        <path d="m8 10 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button class="button button--danger button--wide" type="button" data-cv-delete-button disabled>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 7h14M9 7V5h6v2m-8 0 1 13h8l1-13M10 11v5m4-5v5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Delete
    </button>
  </footer>
</aside>
