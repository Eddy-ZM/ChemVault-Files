<aside id="file-inspector" class="inspector panel" aria-label="Selected file inspector" data-cv-inspector>
  <header class="inspector__header">
    <span class="file-type-icon" data-ext="FILE" data-cv-selected-file-icon>FILE</span>
    <div>
      <h2 data-cv-selected-file-name>Loading files</h2>
    </div>
    <button class="ghost-icon inspector__close" type="button" aria-label="Close inspector" aria-controls="file-inspector" data-cv-inspector-close>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
  </header>

  <nav class="inspector-tabs" aria-label="Inspector tabs" data-cv-inspector-tabs>
    <button class="inspector-tabs__tab is-active" type="button" aria-selected="true" data-cv-inspector-tab="details">Details</button>
    <button class="inspector-tabs__tab" type="button" aria-selected="false" data-cv-inspector-tab="preview">Preview</button>
    <button class="inspector-tabs__tab" type="button" aria-selected="false" data-cv-inspector-tab="activity">Activity</button>
  </nav>

  <div class="inspector__body" data-cv-inspector-body>
    <dl class="metadata-list" data-cv-metadata-list>
      <div><dt>Status</dt><dd>Reading library metadata.</dd></div>
    </dl>
  </div>

  <footer class="inspector__actions">
    <button class="button button--primary button--wide" type="button" data-cv-download-button disabled>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 15v4h14v-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Download
      <svg class="icon button__chevron" viewBox="0 0 24 24" aria-hidden="true">
        <path d="m8 10 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button class="button button--secondary button--wide" type="button" data-cv-share-focus-button disabled>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8.5 12.5 15.5 16M15.5 8 8.5 11.5M18 6.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0ZM8 12a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm10 5.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Share
    </button>
    <div class="inspector__secondary-actions" aria-label="File management actions">
      <button class="button button--secondary" type="button" data-cv-file-action-button="rename" disabled>Rename</button>
      <button class="button button--secondary" type="button" data-cv-file-action-button="move" disabled>Move</button>
      <button class="button button--secondary" type="button" data-cv-file-action-button="copy" disabled>Copy</button>
    </div>
    <button class="button button--danger button--wide" type="button" data-cv-delete-button disabled>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 7h14M9 7V5h6v2m-8 0 1 13h8l1-13M10 11v5m4-5v5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Delete
    </button>
  </footer>
</aside>
