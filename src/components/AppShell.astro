---
import BrandMark from "./BrandMark.astro";
import Sidebar from "./Sidebar.astro";
import Workspace from "./Workspace.astro";
import Inspector from "./Inspector.astro";
---

<div class="files-shell" data-cv-shell data-cv-auth-state="checking" data-cv-sidebar-collapsed="true" data-cv-inspector-collapsed="true" aria-busy="true">
  <a class="skip-link" href="#files-workspace">Skip to files</a>

  <section class="auth-gate" aria-label="Loading ChemVault account" aria-live="polite" data-cv-auth-gate>
    <div class="auth-gate__panel">
      <div class="auth-gate__visual" aria-hidden="true">
        <div class="auth-gate__ring"></div>
        <svg class="auth-gate__folder" viewBox="0 0 36 36" aria-hidden="true">
          <path d="M5.5 13A3.5 3.5 0 0 1 9 9.5h6.3l3.1 3H27A3.5 3.5 0 0 1 30.5 16v9A3.5 3.5 0 0 1 27 28.5H9A3.5 3.5 0 0 1 5.5 25V13Z" fill="currentColor" opacity=".16" />
          <path d="M6.8 14.5h11.7l2.9 3H29M9 28h18a2 2 0 0 0 2-2v-8.5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2V26a2 2 0 0 0 2 2Z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M13 21h10M13 24h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <svg class="auth-gate__key" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.6 9.4a4.2 4.2 0 1 1-1.9-1.9l5.8-5.8L21 4.2l-1.8 1.8 1.4 1.4-2.1 2.1-1.4-1.4-2.5 1.3Z" fill="currentColor" opacity=".18" />
          <path d="M14.6 9.4a4.2 4.2 0 1 1-1.9-1.9l5.8-5.8L21 4.2l-1.8 1.8 1.4 1.4-2.1 2.1-1.4-1.4-2.5 1.3ZM7.5 15.7h.01" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="auth-gate__dots">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
      <div class="auth-gate__copy">
        <span class="auth-gate__title" data-cv-auth-gate-message>loading</span>
      </div>
      <div class="auth-gate__progress" aria-hidden="true">
        <span></span>
      </div>
    </div>
  </section>

  <header class="files-topbar" aria-label="ChemVault Files">
    <div class="files-topbar__brand">
      <button class="sidepanel-toggle" type="button" aria-label="Open Library sidebar" aria-controls="file-sidebar" aria-expanded="false" title="Library" data-cv-sidebar-toggle>
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5.5h16M4 12h16M4 18.5h16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
        </svg>
      </button>
      <BrandMark />
      <p class="files-topbar__subline">private research file system</p>
    </div>

    <form class="files-search" role="search" data-cv-search-form>
      <svg class="icon files-search__icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="m21 21-4.3-4.3m2.3-5.2a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <label class="sr-only" for="files-search-input">Search files, tags, and folders</label>
      <input id="files-search-input" data-cv-search-input type="search" placeholder="Search files, tags, folders..." autocomplete="off" />
      <kbd>Cmd K</kbd>
    </form>

    <div class="files-topbar__actions" aria-label="Account and file actions">
      <button class="button button--primary" type="button" data-cv-upload-button>
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v12m0-12 4.5 4.5M12 3 7.5 7.5M5 13.5V19h14v-5.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="files-topbar__upload-label">Upload files</span>
      </button>
      <button class="icon-button" type="button" aria-label="Help">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9.8 9a2.3 2.3 0 1 1 3.8 1.7c-1.1.8-1.6 1.3-1.6 2.8M12 17.8v.1M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
      <button class="sidepanel-toggle" type="button" aria-label="Open file inspector" aria-controls="file-inspector" aria-expanded="false" title="Inspector" data-cv-inspector-toggle>
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5h8M8 9h8M8 13h5M6.5 3.5h11A1.5 1.5 0 0 1 19 5v14a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 5 19V5a1.5 1.5 0 0 1 1.5-1.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button class="account-chip" type="button" aria-label="ChemVault account" data-cv-account-button>
        <span class="account-chip__avatar" data-cv-account-avatar>CV</span>
        <span class="account-chip__email" data-cv-account-email>owner@chemvault.science</span>
        <svg class="icon account-chip__chevron" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m7 10 5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </header>

  <main class="files-workbench" aria-label="ChemVault Files workbench">
    <Sidebar />
    <Workspace />
    <Inspector />
  </main>
  <button class="sidepanel-scrim" type="button" aria-label="Close sidebars" data-cv-sidepanel-scrim hidden></button>

  <section class="auth-modal" aria-label="ChemVault account sign in" data-cv-auth-modal hidden>
    <div class="auth-modal__scrim" data-cv-auth-close></div>
    <div class="auth-card" role="dialog" aria-modal="true" aria-labelledby="auth-title">
      <header>
        <span class="account-chip__avatar" data-cv-auth-avatar>CV</span>
        <button class="ghost-icon" type="button" aria-label="Close sign in" data-cv-auth-close>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </header>
      <h2 id="auth-title">ChemVault Files</h2>
      <p>Signed in through ChemVault User. File actions are recorded with this account.</p>
      <div class="auth-form">
        <label>
          <span>Email</span>
          <input data-cv-auth-email type="email" value="owner@chemvault.science" autocomplete="email" readonly />
        </label>
        <div class="auth-actions">
          <a class="button button--primary button--wide" href="https://user.chemvault.science/login" data-cv-login-link data-cv-unauthenticated-only>Sign in through User Center</a>
          <button class="button button--primary button--wide" type="button" data-cv-auth-close data-cv-authenticated-only>Continue as current user</button>
          <button class="button button--secondary button--wide" type="button" data-cv-logout-button data-cv-authenticated-only>Sign out</button>
        </div>
      </div>
      <small>ChemVault User supplies the login email and file permissions.</small>
    </div>
  </section>

  <section class="auth-modal role-modal" aria-label="ChemVault role permissions" data-cv-role-modal hidden>
    <div class="auth-modal__scrim" data-cv-role-close></div>
    <div class="auth-card role-card" role="dialog" aria-modal="true" aria-labelledby="role-title">
      <header>
        <span class="account-chip__avatar" data-cv-auth-avatar>CV</span>
        <button class="ghost-icon" type="button" aria-label="Close role permissions" data-cv-role-close>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </header>
      <h2 id="role-title">Role</h2>
      <p>Set file visibility roles for ChemVault User accounts.</p>
      <section class="role-settings" aria-label="File role permissions" data-cv-role-settings>
        <div class="role-settings__empty">Loading role permissions...</div>
      </section>
    </div>
  </section>

  <section class="auth-modal upload-modal" aria-label="Upload files and folders" data-cv-upload-modal hidden>
    <div class="auth-modal__scrim" data-cv-upload-close></div>
    <div class="auth-card upload-card" role="dialog" aria-modal="true" aria-labelledby="upload-title">
      <header>
        <span class="upload-card__icon">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3v11m0-11 4 4M12 3 8 7M5 14v4.5A2.5 2.5 0 0 0 7.5 21h9a2.5 2.5 0 0 0 2.5-2.5V14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <button class="ghost-icon" type="button" aria-label="Close upload" data-cv-upload-close>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </header>
      <h2 id="upload-title" data-cv-upload-title>Upload Queue</h2>
      <p>Upload files or complete folders. Folder structure is added to the sidebar while uploads are prepared.</p>

      <div class="upload-picker-grid upload-picker-grid--single" aria-label="Upload source">
        <div class="upload-choice upload-choice--unified">
          <input class="sr-only" type="file" multiple data-cv-file-input />
          <input class="sr-only" type="file" multiple data-cv-folder-input />
          <span>Choose files or folder</span>
          <small>Files use the active folder; folders keep their tree automatically.</small>
          <div class="upload-choice__actions">
            <button type="button" data-cv-file-picker>Files</button>
            <button type="button" data-cv-folder-picker>Folder</button>
          </div>
        </div>
      </div>

      <section class="upload-access" aria-label="Upload file access" data-cv-upload-access>
        <div class="role-settings__empty">Loading upload access controls...</div>
      </section>

      <label class="upload-dropzone" data-cv-file-dropzone>
        <span class="upload-dropzone__icon">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H10l2 2h4.5A2.5 2.5 0 0 1 19 8.5v9A2.5 2.5 0 0 1 16.5 20h-9A2.5 2.5 0 0 1 5 17.5v-11Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            <path d="M12 10v6m0-6 2.5 2.5M12 10l-2.5 2.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span>
          <strong>Drop files or folders to upload</strong>
          <small>R2-backed queue accepts spectra, datasets, dossiers, and manuscripts.</small>
        </span>
        <span class="upload-dropzone__action">Drop here</span>
      </label>

      <ul class="upload-list" aria-label="Current uploads" data-cv-upload-list>
        <li class="upload-row upload-row--empty">Ready for direct R2 upload. Choose files or a folder to start.</li>
      </ul>
    </div>
  </section>
</div>
