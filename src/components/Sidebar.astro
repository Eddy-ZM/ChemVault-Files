<aside class="sidebar panel" aria-label="File navigation" data-cv-sidebar>
  <nav class="sidebar__section sidebar__section--top" aria-labelledby="library-label">
    <div class="section-heading">
      <h2 id="library-label">Library</h2>
      <button class="ghost-icon" type="button" aria-label="Create project">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <ul class="nav-list">
      <li>
        <a class="nav-row" href="#" data-cv-nav="all-files" aria-current="page">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H10l2 2h4.5A2.5 2.5 0 0 1 19 8.5v9A2.5 2.5 0 0 1 16.5 20h-9A2.5 2.5 0 0 1 5 17.5v-11Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            <path d="M8 12h8M8 15h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
          <span>All Files</span>
          <strong data-cv-all-files-count>0</strong>
        </a>
      </li>
    </ul>
  </nav>

  <nav class="sidebar__section" aria-labelledby="folders-label">
    <div class="section-heading">
      <h2 id="folders-label">Projects &amp; Folders</h2>
      <button class="ghost-icon" type="button" aria-label="Create folder">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <ul class="folder-tree" data-cv-folder-tree>
      <li class="empty-state">Loading projects...</li>
    </ul>
  </nav>

  <section class="sidebar__section sidebar__section--tags" aria-labelledby="tags-label">
    <div class="section-heading">
      <h2 id="tags-label">Tags</h2>
      <button class="ghost-icon" type="button" aria-label="Edit tags">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m4 20 4.5-1 10-10a2.1 2.1 0 0 0-3-3l-10 10L4 20Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <div class="tag-cloud" data-cv-tags></div>
    <button class="link-button" type="button" data-cv-new-tag>+ New tag</button>
  </section>

  <nav class="sidebar__section sidebar__section--admin" aria-labelledby="admin-label" data-cv-role-section>
    <div class="section-heading">
      <h2 id="admin-label">Administration</h2>
    </div>
    <ul class="nav-list">
      <li>
        <button class="nav-row nav-row--button" type="button" data-cv-role-button>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 10V7a5 5 0 0 1 10 0v3M6.5 10h11A1.5 1.5 0 0 1 19 11.5v7A1.5 1.5 0 0 1 17.5 20h-11A1.5 1.5 0 0 1 5 18.5v-7A1.5 1.5 0 0 1 6.5 10Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          <span>Role</span>
          <strong data-cv-role-nav-permission>读写</strong>
        </button>
      </li>
    </ul>
  </nav>

  <section class="storage-meter" aria-labelledby="storage-label">
    <div class="storage-meter__label">
      <h2 id="storage-label">Storage</h2>
      <span data-cv-storage-caption>Preview index loading</span>
    </div>
    <div class="meter" aria-hidden="true"><span style="width: 0%" data-cv-storage-meter></span></div>
    <p data-cv-storage-percent>0%</p>
  </section>
</aside>
