<aside id="file-sidebar" class="sidebar panel" aria-label="File navigation" data-cv-sidebar>
  <section class="sidebar__section sidebar__section--actions" aria-labelledby="actions-label">
    <div class="section-heading">
      <h2 id="actions-label">New</h2>
    </div>
    <div class="sidebar-action-stack">
      <button class="sidebar-action sidebar-action--primary" type="button" data-cv-sidebar-action="upload" data-cv-rail-label="Upload">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v11m0-11 4 4M12 3 8 7M5 14v4.5A2.5 2.5 0 0 0 7.5 21h9a2.5 2.5 0 0 0 2.5-2.5V14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>
          <strong>Upload</strong>
          <small>Private by default</small>
        </span>
      </button>
      <button class="sidebar-action" type="button" data-cv-sidebar-action="new-folder" data-cv-rail-label="New folder">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 7.5A2.5 2.5 0 0 1 7.5 5H10l2 2h4.5A2.5 2.5 0 0 1 19 9.5v7A2.5 2.5 0 0 1 16.5 19h-9A2.5 2.5 0 0 1 5 16.5v-9Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          <path d="M12 10v5M9.5 12.5h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>
          <strong>New folder</strong>
          <small>Inside current project</small>
        </span>
      </button>
    </div>
  </section>

  <nav class="sidebar__section sidebar__section--top" aria-labelledby="library-label">
    <div class="section-heading">
      <h2 id="library-label">Drive</h2>
    </div>

    <ul class="nav-list">
      <li>
        <a class="nav-row" href="/files" aria-label="My Files" data-cv-nav="all-files" data-cv-rail-label="My Files" aria-current="page">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H10l2 2h4.5A2.5 2.5 0 0 1 19 8.5v9A2.5 2.5 0 0 1 16.5 20h-9A2.5 2.5 0 0 1 5 17.5v-11Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            <path d="M8 12h8M8 15h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
          <span>My Files</span>
          <strong data-cv-all-files-count>0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/recent" aria-label="Recent files" data-cv-nav="recent" data-cv-rail-label="Recent">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 7v5l3 2M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Recent</span>
          <strong data-cv-nav-count="recent">0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/starred" aria-label="Starred files" data-cv-nav="starred" data-cv-rail-label="Starred">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m12 3.8 2.5 5.1 5.6.8-4 3.9.9 5.5-5-2.6-5 2.6.9-5.5-4-3.9 5.6-.8L12 3.8Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
          </svg>
          <span>Starred</span>
          <strong data-cv-nav-count="starred">0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/shared" aria-label="Shared with me" data-cv-nav="shared" data-cv-rail-label="Shared">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.5 12.5h7M9.5 8.5H8A3.5 3.5 0 1 0 8 15.5h1.5M14.5 8.5H16a3.5 3.5 0 1 1 0 7h-1.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Shared with me</span>
          <strong data-cv-nav-count="shared">0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/trash" aria-label="Recycle Bin" data-cv-nav="trash" data-cv-rail-label="Trash">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 7h14M9 7V5h6v2m-8 0 1 13h8l1-13M10 11v5m4-5v5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Recycle Bin</span>
          <strong data-cv-nav-count="trash">0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/settings" aria-label="Storage" data-cv-nav="storage" data-cv-rail-label="Storage">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 18h16M7 18V8m5 10V5m5 13v-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Storage</span>
          <strong data-cv-nav-count="large">0</strong>
        </a>
      </li>
      <li>
        <a class="nav-row" href="/files/settings" aria-label="Settings" data-cv-nav="settings" data-cv-rail-label="Settings">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 15.2A3.2 3.2 0 1 0 12 8.8a3.2 3.2 0 0 0 0 6.4ZM19.4 15a8.2 8.2 0 0 0 .1-1l2-1.5-2-3.4-2.4 1a8 8 0 0 0-1.7-1L15 6.5h-6l-.4 2.6a8 8 0 0 0-1.7 1l-2.4-1-2 3.4 2 1.5a8.2 8.2 0 0 0 .1 2l-2 1.5 2 3.4 2.4-1a8 8 0 0 0 1.7 1l.4 2.6h6l.4-2.6a8 8 0 0 0 1.7-1l2.4 1 2-3.4-2-1.5c.1-.3.1-.7.1-1Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
          </svg>
          <span>Settings</span>
          <strong></strong>
        </a>
      </li>
    </ul>
  </nav>

  <nav class="sidebar__section sidebar__section--folders" aria-labelledby="folders-label">
    <div class="section-heading">
      <h2 id="folders-label">Projects &amp; Folders</h2>
    </div>

    <ul class="folder-tree" data-cv-folder-tree>
      <li class="empty-state">Loading projects...</li>
    </ul>
  </nav>

  <section class="sidebar__section sidebar__section--tags" aria-labelledby="tags-label">
    <div class="section-heading">
      <h2 id="tags-label">Tags</h2>
    </div>
    <div class="tag-cloud" data-cv-tags></div>
  </section>

  <nav class="sidebar__section sidebar__section--admin" aria-labelledby="admin-label" data-cv-role-section>
    <div class="section-heading">
      <h2 id="admin-label">Administration</h2>
    </div>
    <ul class="nav-list">
      <li>
        <button class="nav-row nav-row--button" type="button" aria-label="Role administration" data-cv-rail-label="Role administration" data-cv-role-button>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 10V7a5 5 0 0 1 10 0v3M6.5 10h11A1.5 1.5 0 0 1 19 11.5v7A1.5 1.5 0 0 1 17.5 20h-11A1.5 1.5 0 0 1 5 18.5v-7A1.5 1.5 0 0 1 6.5 10Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          <span>Role</span>
          <strong data-cv-role-nav-permission>读写</strong>
        </button>
      </li>
    </ul>
  </nav>

  <section class="storage-meter" aria-labelledby="storage-label">
    <div class="storage-meter__label">
      <h2 id="storage-label">Storage</h2>
      <span data-cv-storage-caption>Preview index loading</span>
    </div>
    <div class="meter" aria-hidden="true"><span style="width: 0%" data-cv-storage-meter></span></div>
    <p data-cv-storage-percent>0%</p>
  </section>
</aside>
