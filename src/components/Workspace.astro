<section id="files-workspace" class="workspace" aria-label="Files workspace" data-cv-workspace>
  <section class="workspace-command panel" aria-label="Workspace views">
    <div class="workspace-command__summary">
      <span class="workspace-command__eyebrow">ChemVault workspace</span>
      <h1>Research file operations</h1>
      <p>Private spectra, datasets, dossiers, and manuscripts.</p>
    </div>
    <nav class="workspace-switcher" aria-label="Workspace view selector" role="tablist">
      <button id="workspace-tab-library" class="workspace-switcher__button is-active" type="button" role="tab" aria-selected="true" aria-controls="workspace-panel-library" data-cv-workspace-view-button="library">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H10l2 2h4.5A2.5 2.5 0 0 1 19 8.5v9A2.5 2.5 0 0 1 16.5 20h-9A2.5 2.5 0 0 1 5 17.5v-11Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          <path d="M8 12h8M8 15h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>Library</span>
        <small>Files table</small>
      </button>
      <button id="workspace-tab-flow" class="workspace-switcher__button" type="button" role="tab" aria-selected="false" aria-controls="workspace-panel-flow" data-cv-workspace-view-button="flow">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7h4l2 10h4l2-10h4M8 7c0 6 8 4 8 10M16 7c0 6-8 4-8 10" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Review Flow</span>
        <small>Queue lanes</small>
      </button>
      <button id="workspace-tab-insights" class="workspace-switcher__button" type="button" role="tab" aria-selected="false" aria-controls="workspace-panel-insights" data-cv-workspace-view-button="insights">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 19V5m0 14h16M8 16v-5m4 5V8m4 8v-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Insights</span>
        <small>Storage map</small>
      </button>
    </nav>
  </section>

  <section class="workspace-overview" aria-label="File library overview">
    <section class="status-band panel" aria-label="System status" data-cv-status-band>
      <div class="status-item">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 10V7a5 5 0 0 1 10 0v3M6.5 10h11A1.5 1.5 0 0 1 19 11.5v7A1.5 1.5 0 0 1 17.5 20h-11A1.5 1.5 0 0 1 5 18.5v-7A1.5 1.5 0 0 1 6.5 10Z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round" />
        </svg>
        <span class="status-dot"></span>
        <span>Private Access</span>
      </div>
      <div class="status-item">
        <span class="status-dot"></span>
        <span>R2 online</span>
      </div>
      <div class="status-item">
        <span class="status-dot"></span>
        <span>D1 index</span>
      </div>
      <div class="status-item status-item--end">
        <span class="status-dot"></span>
        <span>Ready</span>
      </div>
    </section>

    <section class="insight-strip" aria-label="File library summary" data-cv-insights>
      <article class="insight-card">
        <span>Indexed Storage</span>
        <strong>Loading</strong>
        <small>Reading D1 index</small>
      </article>
      <article class="insight-card">
        <span>Ready Files</span>
        <strong>Loading</strong>
        <small>Checking R2 objects</small>
      </article>
      <article class="insight-card">
        <span>Needs Review</span>
        <strong>Loading</strong>
        <small>Checking uploads</small>
      </article>
      <article class="insight-card">
        <span>Largest Object</span>
        <strong>Loading</strong>
        <small>Reading metadata</small>
      </article>
    </section>
  </section>

  <section id="workspace-panel-library" class="workspace-view file-panel panel is-active" aria-labelledby="workspace-tab-library" role="tabpanel" data-cv-workspace-view="library" data-cv-file-panel>
    <div class="file-panel__header">
      <div>
        <h2 id="files-title" data-cv-files-title>Files</h2>
        <div class="active-filters" aria-label="Active filters" data-cv-active-filters></div>
      </div>
      <div class="file-tools" aria-label="File table tools">
        <button class="button button--secondary" type="button" data-cv-quick-filter="failed">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 5h16l-6 7v5l-4 2v-7L4 5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          Failed
        </button>
        <button class="button button--secondary" type="button" data-cv-quick-filter="large">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 18h16M7 18V8m5 10V5m5 13v-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Large
        </button>
        <div class="segmented-control" aria-label="View mode">
          <button class="segmented-control__button segmented-control__button--active" type="button" aria-label="List view" data-cv-view-mode="list" aria-pressed="true">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
          <button class="segmented-control__button" type="button" aria-label="Grid view" data-cv-view-mode="grid" aria-pressed="false">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 5h6v6H5V5Zm8 0h6v6h-6V5ZM5 13h6v6H5v-6Zm8 0h6v6h-6v-6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="smart-filter-row" aria-label="Smart filters" data-cv-smart-filters>
      <button class="smart-chip is-active" type="button" data-cv-quick-filter="">All files</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="ready">Ready</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="failed">Needs review</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="large">Large objects</button>
    </div>

    <section class="file-browser" aria-label="Folders and files" data-cv-file-browser>
      <header class="file-browser__header">
        <nav class="file-browser__path" aria-label="Current folder" data-cv-file-browser-path>
          <button type="button" data-cv-browser-root>Vault</button>
        </nav>
        <span data-cv-file-browser-summary>Loading</span>
      </header>
      <div class="file-browser__grid" data-cv-file-browser-grid>
        <div class="empty-state">Loading file browser...</div>
      </div>
    </section>

    <div class="file-browser__list" data-cv-list-region hidden>
      <div class="file-table-wrap">
        <table class="file-table" data-cv-file-table>
          <thead>
            <tr>
              <th scope="col" class="select-cell">
                <label class="checkbox"><input type="checkbox" data-cv-select-all /><span></span><span class="sr-only">Select all files</span></label>
              </th>
              <th scope="col"><button class="table-sort" type="button" data-cv-sort="name">Name <span class="sort-icon" aria-hidden="true"></span></button></th>
              <th scope="col">Tags</th>
              <th scope="col"><button class="table-sort" type="button" data-cv-sort="type">Type</button></th>
              <th scope="col"><button class="table-sort" type="button" data-cv-sort="size">Size <span class="sort-icon" aria-hidden="true"></span></button></th>
              <th scope="col"><button class="table-sort" type="button" data-cv-sort="modified">Modified <span class="sort-icon" aria-hidden="true"></span></button></th>
              <th scope="col" class="icon-cell"><span class="sr-only">Starred</span></th>
              <th scope="col" class="icon-cell"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody data-cv-file-table-body>
            <tr><td colspan="8"><div class="empty-state">Loading file index...</div></td></tr>
          </tbody>
        </table>
      </div>
      <footer class="table-footer">
        <span data-cv-selection-summary>No files checked</span>
        <div class="pagination" aria-label="Pagination">
          <span>Show</span>
          <button class="plain-select" type="button">50
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m8 10 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <span data-cv-page-summary>Loading</span>
          <button class="ghost-icon" type="button" aria-label="Previous page">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button class="ghost-icon" type="button" aria-label="Next page">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </footer>
    </div>

    <div class="file-card-grid" data-cv-card-grid hidden></div>

    <div class="bulk-action-bar" data-cv-bulk-bar hidden>
      <span data-cv-bulk-summary>1 selected</span>
      <div>
        <button class="button button--secondary" type="button" data-cv-bulk-download>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 15v4h14v-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Download
        </button>
        <button class="button button--secondary" type="button" data-cv-bulk-tag>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7.5V12l7.5 7.5 7-7L11 5H6.5A2.5 2.5 0 0 0 4 7.5Zm4 1.5h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Tag
        </button>
        <button class="button button--danger" type="button" data-cv-bulk-delete>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 11v6m6-6v6M5 7h14m-2 0-.8 12.2A2 2 0 0 1 14.2 21H9.8a2 2 0 0 1-2-1.8L7 7m3-3h4l1 3H9l1-3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Delete
        </button>
        <button class="button button--danger" type="button" data-cv-bulk-clear>Clear selection</button>
      </div>
    </div>
  </section>

  <section id="workspace-panel-flow" class="workspace-view flow-panel panel" aria-labelledby="workspace-tab-flow" role="tabpanel" data-cv-workspace-view="flow" hidden>
    <header class="workspace-panel-header">
      <div>
        <h2>Review Flow</h2>
        <p>Intake, indexing, review, release.</p>
      </div>
      <button class="button button--secondary" type="button" data-cv-quick-filter="failed">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5h16l-6 7v5l-4 2v-7L4 5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        </svg>
        Focus review
      </button>
    </header>
    <div class="flow-lanes" data-cv-flow-lanes>
      <article class="flow-lane"><span>Intake</span><strong>Loading</strong><small>Reading library</small></article>
      <article class="flow-lane"><span>Indexed</span><strong>Loading</strong><small>Reading D1</small></article>
      <article class="flow-lane"><span>Review</span><strong>Loading</strong><small>Checking failed uploads</small></article>
      <article class="flow-lane"><span>Released</span><strong>Loading</strong><small>Checking visibility</small></article>
    </div>
    <div class="flow-grid">
      <section class="flow-timeline" aria-label="Recent file activity">
        <h3>Recent activity</h3>
        <ol data-cv-flow-timeline>
          <li class="flow-empty">Loading activity...</li>
        </ol>
      </section>
      <section class="flow-checklist" aria-label="Review checklist">
        <h3>Review checklist</h3>
        <ul>
          <li><span class="status-dot"></span><strong>Checksum captured</strong><small>Validate object integrity before release.</small></li>
          <li><span class="status-dot"></span><strong>Access policy set</strong><small>Confirm role visibility for sensitive results.</small></li>
          <li><span class="status-dot status-dot--warning"></span><strong>Failed uploads isolated</strong><small>Use the review filter to retry or remove stale objects.</small></li>
        </ul>
      </section>
    </div>
  </section>

  <section id="workspace-panel-insights" class="workspace-view insights-panel panel" aria-labelledby="workspace-tab-insights" role="tabpanel" data-cv-workspace-view="insights" hidden>
    <header class="workspace-panel-header">
      <div>
        <h2>Vault Insights</h2>
        <p>Storage distribution, tag concentration, operational readiness.</p>
      </div>
      <button class="button button--secondary" type="button" data-cv-quick-filter="large">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 18h16M7 18V8m5 10V5m5 13v-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Large objects
      </button>
    </header>
    <div class="insights-board" data-cv-insights-board>
      <div class="insight-board-empty">Loading vault intelligence...</div>
    </div>
  </section>
</section>
