---
const uploads = [
  {
    name: "2024-05-21_NMR_Compound_14.zip",
    size: "1.24 GB",
    state: "uploading",
    progress: "68%",
    time: "2m 18s left",
    extension: "ZIP",
  },
  {
    name: "kinetics_run_042_processed.csv",
    size: "45.7 MB",
    state: "completed",
    progress: "Completed",
    time: "45.7 MB",
    extension: "CSV",
  },
];

const files = [
  {
    name: "2024-05-21_NMR_Compound_14.zip",
    tags: ["NMR", "Raw Data", "+2"],
    type: "ZIP",
    size: "1.24 GB",
    modified: "May 21, 2024 10:42 AM",
    ext: "ZIP",
  },
  {
    name: "Compound_14_1H.jdx",
    tags: ["NMR", "1H", "+1"],
    type: "JCAMP-DX",
    size: "12.6 MB",
    modified: "May 21, 2024 10:41 AM",
    ext: "JCAMP",
    selected: true,
    starred: true,
  },
  {
    name: "Compound_14_13C.jdx",
    tags: ["NMR", "13C"],
    type: "JCAMP-DX",
    size: "18.3 MB",
    modified: "May 21, 2024 10:40 AM",
    ext: "JCAMP",
  },
  {
    name: "NMR_Analysis_Report_Compound_14.pdf",
    tags: ["NMR"],
    type: "PDF",
    size: "1.8 MB",
    modified: "May 21, 2024 10:39 AM",
    ext: "PDF",
    accent: "red",
  },
  {
    name: "kinetics_run_042_processed.csv",
    tags: ["Kinetics", "Raw Data"],
    type: "CSV",
    size: "45.7 MB",
    modified: "May 20, 2024 4:22 PM",
    ext: "CSV",
    accent: "green",
  },
  {
    name: "dataset_reaction_screen_042.h5",
    tags: ["Raw Data", "Screen"],
    type: "HDF5",
    size: "2.31 GB",
    modified: "May 20, 2024 3:15 PM",
    ext: "HDF5",
    accent: "violet",
  },
  {
    name: "failed_upload_package.zip",
    tags: ["Raw Data"],
    type: "ZIP",
    size: "3.62 GB",
    modified: "May 20, 2024 2:11 PM",
    ext: "ZIP",
    failed: true,
  },
  {
    name: "Supplementary_Information.pdf",
    tags: ["SI", "PDF"],
    type: "PDF",
    size: "2.4 MB",
    modified: "May 19, 2024 11:08 AM",
    ext: "PDF",
    accent: "red",
  },
  {
    name: "Compound_13_1H.jdx",
    tags: ["NMR", "1H"],
    type: "JCAMP-DX",
    size: "11.2 MB",
    modified: "May 19, 2024 10:36 AM",
    ext: "JCAMP",
  },
  {
    name: "FTIR_Compound_14.dat",
    tags: ["IR"],
    type: "DAT",
    size: "6.7 MB",
    modified: "May 18, 2024 3:47 PM",
    ext: "DAT",
    accent: "teal",
  },
];
---

<section id="files-workspace" class="workspace" aria-label="Files workspace" data-cv-workspace>
  <section class="status-band panel" aria-label="System status" data-cv-status-band>
    <div class="status-item">
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M7 10V7a5 5 0 0 1 10 0v3M6.5 10h11A1.5 1.5 0 0 1 19 11.5v7A1.5 1.5 0 0 1 17.5 20h-11A1.5 1.5 0 0 1 5 18.5v-7A1.5 1.5 0 0 1 6.5 10Z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round" />
      </svg>
      <span class="status-dot"></span>
      <span>Private Access</span>
    </div>
    <div class="status-item">
      <span class="status-dot"></span>
      <span>R2 online</span>
    </div>
    <div class="status-item">
      <span class="status-dot"></span>
      <span>D1 index</span>
    </div>
    <div class="status-item status-item--end">
      <span class="status-dot"></span>
      <span>Ready</span>
    </div>
  </section>

  <section class="insight-strip" aria-label="File library summary" data-cv-insights>
    <article class="insight-card">
      <span>Indexed Storage</span>
      <strong>1.32 TB</strong>
      <small>10 preview files</small>
    </article>
    <article class="insight-card">
      <span>Ready Files</span>
      <strong>9</strong>
      <small>R2 objects ready</small>
    </article>
    <article class="insight-card insight-card--warning">
      <span>Needs Review</span>
      <strong>1</strong>
      <small>failed upload</small>
    </article>
    <article class="insight-card">
      <span>Largest Object</span>
      <strong>3.6 GB</strong>
      <small>failed_upload_package.zip</small>
    </article>
  </section>

  <section class="upload-panel panel" aria-labelledby="upload-queue-title" data-cv-upload-zone>
    <div class="panel-toolbar">
      <div>
        <h2 id="upload-queue-title" data-cv-upload-title>Upload Queue (2)</h2>
        <button class="toolbar-caret" type="button" aria-label="Collapse upload queue">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m8 10 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
      <div class="panel-toolbar__actions">
        <button class="link-button" type="button">Clear completed</button>
        <button class="button button--secondary" type="button">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14M16 5v14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          Pause all
        </button>
      </div>
    </div>

    <label class="upload-dropzone" data-cv-file-dropzone>
      <input class="sr-only" type="file" multiple data-cv-file-input />
      <span class="upload-dropzone__icon">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v11m0-11 4 4M12 3 8 7M5 14v4.5A2.5 2.5 0 0 0 7.5 21h9a2.5 2.5 0 0 0 2.5-2.5V14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span>
        <strong>Drop files to upload</strong>
        <small>R2-backed queue accepts spectra, datasets, dossiers, and manuscripts.</small>
      </span>
      <span class="upload-dropzone__action">Choose files</span>
    </label>

    <ul class="upload-list" aria-label="Current uploads" data-cv-upload-list>
      {uploads.map((upload) => (
        <li class="upload-row" data-cv-upload-row>
          <span class="file-type-icon" data-ext={upload.extension}>{upload.extension}</span>
          <span class="upload-row__name">{upload.name}</span>
          <span class="upload-row__size">{upload.size}</span>
          {upload.state === "uploading" ? (
            <span class="progress" aria-label={`Upload progress ${upload.progress}`} role="progressbar" aria-valuenow="68" aria-valuemin="0" aria-valuemax="100">
              <span style="width: 68%"></span>
            </span>
          ) : (
            <span class="upload-complete">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="m7 12 3.2 3.2L17.5 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8" />
              </svg>
              Completed
            </span>
          )}
          <span class="upload-row__progress">{upload.state === "uploading" ? upload.progress : ""}</span>
          <span class="upload-row__time">{upload.time}</span>
          <button class="ghost-icon" type="button" aria-label={`Remove ${upload.name} from queue`}>
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </li>
      ))}
    </ul>
  </section>

  <section class="file-panel panel" aria-labelledby="files-title" data-cv-file-panel>
    <div class="file-panel__header">
      <div>
        <h2 id="files-title" data-cv-files-title>Files (212)</h2>
        <div class="active-filters" aria-label="Active filters" data-cv-active-filters>
          <button class="filter-chip" type="button" data-cv-active-filter="Spectra">
            Spectra
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
          <button class="link-button" type="button">Clear filters</button>
        </div>
      </div>
      <div class="file-tools" aria-label="File table tools">
        <button class="button button--secondary" type="button" data-cv-quick-filter="failed">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 5h16l-6 7v5l-4 2v-7L4 5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          Failed
        </button>
        <button class="button button--secondary" type="button" data-cv-quick-filter="large">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 18h16M7 18V8m5 10V5m5 13v-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Large
        </button>
        <div class="segmented-control" aria-label="View mode">
          <button class="segmented-control__button segmented-control__button--active" type="button" aria-label="List view" data-cv-view-mode="list" aria-pressed="true">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
          <button class="segmented-control__button" type="button" aria-label="Grid view" data-cv-view-mode="grid" aria-pressed="false">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 5h6v6H5V5Zm8 0h6v6h-6V5ZM5 13h6v6H5v-6Zm8 0h6v6h-6v-6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="smart-filter-row" aria-label="Smart filters" data-cv-smart-filters>
      <button class="smart-chip is-active" type="button" data-cv-quick-filter="">All files</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="ready">Ready</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="failed">Needs review</button>
      <button class="smart-chip" type="button" data-cv-quick-filter="large">Large objects</button>
    </div>

    <div class="bulk-action-bar" data-cv-bulk-bar hidden>
      <span data-cv-bulk-summary>1 selected</span>
      <div>
        <button class="button button--secondary" type="button" data-cv-bulk-download>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 15v4h14v-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Download
        </button>
        <button class="button button--secondary" type="button" data-cv-bulk-tag>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7.5V12l7.5 7.5 7-7L11 5H6.5A2.5 2.5 0 0 0 4 7.5Zm4 1.5h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Tag
        </button>
        <button class="button button--danger" type="button" data-cv-bulk-clear>Clear selection</button>
      </div>
    </div>

    <div class="file-table-wrap" data-cv-list-region>
      <table class="file-table" data-cv-file-table>
        <thead>
          <tr>
            <th scope="col" class="select-cell">
              <label class="checkbox"><input type="checkbox" data-cv-select-all /><span></span><span class="sr-only">Select all files</span></label>
            </th>
            <th scope="col"><button class="table-sort" type="button" data-cv-sort="name">Name <span class="sort-icon" aria-hidden="true"></span></button></th>
            <th scope="col">Tags</th>
            <th scope="col"><button class="table-sort" type="button" data-cv-sort="type">Type</button></th>
            <th scope="col"><button class="table-sort" type="button" data-cv-sort="size">Size <span class="sort-icon" aria-hidden="true"></span></button></th>
            <th scope="col"><button class="table-sort" type="button" data-cv-sort="modified">Modified <span class="sort-icon" aria-hidden="true"></span></button></th>
            <th scope="col" class="icon-cell"><span class="sr-only">Starred</span></th>
            <th scope="col" class="icon-cell"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody data-cv-file-table-body>
          {files.map((file) => (
            <tr class:list={[{ "is-selected": file.selected, "is-failed": file.failed }]} data-cv-file-row data-file-name={file.name}>
              <td class="select-cell">
                <label class="checkbox"><input type="checkbox" checked={file.selected} /><span></span><span class="sr-only">Select {file.name}</span></label>
              </td>
              <td>
                <a href="#" class="file-name">
                  <span class:list={["file-type-icon", file.accent && `file-type-icon--${file.accent}`]} data-ext={file.ext}>{file.ext}</span>
                  <span>{file.name}</span>
                </a>
              </td>
              <td>
                <span class="chip-list">
                  {file.tags.map((tag) => <span class="mini-chip">{tag}</span>)}
                </span>
              </td>
              <td>{file.type}</td>
              <td>{file.size}</td>
              <td class="date-cell">{file.modified}</td>
              <td class="icon-cell">
                {file.failed ? (
                  <span class="failed-state">
                    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m12 4 9 16H3l9-16Zm0 5v5m0 3v.1" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Failed
                  </span>
                ) : (
                  <button class:list={["star-button", { "is-active": file.starred }]} type="button" aria-label={file.starred ? "Remove star" : "Star file"}>
                    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m12 3.8 2.5 5.1 5.6.8-4.1 4 1 5.6-5-2.6-5 2.6 1-5.6-4.1-4 5.6-.8L12 3.8Z" fill={file.starred ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                    </svg>
                  </button>
                )}
              </td>
              <td class="icon-cell">
                {file.failed ? <button class="link-button" type="button">Retry</button> : null}
                <button class="ghost-icon" type="button" aria-label={`Open actions for ${file.name}`}>
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 6.5h.01M12 12h.01M12 17.5h.01" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                  </svg>
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="file-card-grid" data-cv-card-grid hidden></div>

    <footer class="table-footer">
      <span data-cv-selection-summary>1 selected</span>
      <div class="pagination" aria-label="Pagination">
        <span>Show</span>
        <button class="plain-select" type="button">50
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m8 10 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <span data-cv-page-summary>1-50 of 212</span>
        <button class="ghost-icon" type="button" aria-label="Previous page">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button class="ghost-icon" type="button" aria-label="Next page">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </footer>
  </section>
</section>
