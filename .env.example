CHEMVAULT_API_BASE_URL=https://file.chemvault.science
CHEMVAULT_APP_ENV=production
CHEMVAULT_UPDATE_FEED_URL=https://download.chemvault.science/files/windows/

# Cloudflare Pages / Workers runtime values
ALLOWED_APP_ORIGINS=null app://chemvault-files http://127.0.0.1:5177 http://localhost:5177
FILE_STORAGE_QUOTA_BYTES=10737418240

# Set as a Cloudflare secret, not in source control.
APP_SESSION_SECRET=
LIFECYCLE_SERVICE_SECRET=replace_with_a_dedicated_cross_service_secret
LAB_HANDOFF_SECRET=replace_with_a_dedicated_files_to_lab_secret
FILE_SCAN_CALLBACK_SECRET=replace_with_a_dedicated_scanner_secret
ARTIFACT_WRITE_SECRET=replace_with_a_dedicated_artifact_writer_secret
PUBLIC_CHEMVAULT_LAB_URL=https://lab.chemvault.science/analyse
